---
interface Props {
  page: { path: string; label: string; icon: (props: { class?: string; "aria-hidden"?: boolean }) => unknown };
  isActive: boolean;
}
const { page, isActive } = Astro.props;
const Icon = page.icon;
---
<a
  href={page.path}
  class:list={[
    "flex-1 flex flex-col md:flex-row items-center justify-center gap-1 min-h-[56px] py-2 px-3 rounded-none text-sm touch-manipulation md:w-full",
    isActive && "text-base-100 bg-primary",
    !isActive && "text-base-content/70 active:bg-base-300",
  ]}
>
  <Icon class="h-6 w-6 shrink-0" aria-hidden />
  <span>{page.label}</span>
</a>
